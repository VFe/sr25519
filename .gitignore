# Elixir / Mix
/_build/
/cover/
/deps/
/doc/
/.fetch
erl_crash.dump
*.ez
*.beam
/config/*.secret.exs
.elixir_ls/

# Rust / native build artifacts (never committed; NIFs are precompiled in CI)
/native/*/target/
/native/**/*.so
/native/**/*.dll
/native/**/*.dylib
# Force-built NIF that rustler copies into priv/ during local dev
/priv/

# Oracle generator scratch (vectors themselves ARE committed under test/vectors/)
/vectors/node/node_modules/
/vectors/python/__pycache__/
/vectors/python/.venv/
/vectors/**/target/

# Conformance harness output
/conformance_report.json

# NOTE: checksum-Elixir.Sr25519.Native.exs is deliberately NOT gitignored — the
# release flow generates it (mix rustler_precompiled.download --all) and must
# commit it, and the Hex package is non-functional without it. Between releases
# it simply doesn't exist (the L7 test creates and removes a transient one).

# OS / editor
.DS_Store
*.swp
